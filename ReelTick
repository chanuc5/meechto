    <!-- HIGH PERFORMANCE VANILLA SCRIPT ENGINE -->
    <!-- ====================================== -->
    <script>
        // --- SECURE THEME SWITCHER LOGIC ---
        const themeBtn = document.getElementById('themeBtn');
        const currentTheme = localStorage.getItem('reeltick-theme') || 'light';
        
        document.documentElement.setAttribute('data-theme', currentTheme);
        updateThemeIcon(currentTheme);

        themeBtn.addEventListener('click', () => {
            let theme = document.documentElement.getAttribute('data-theme');
            let nextTheme = (theme === 'dark') ? 'light' : 'dark';
            
            document.documentElement.setAttribute('data-theme', nextTheme);
            localStorage.setItem('reeltick-theme', nextTheme);
            updateThemeIcon(nextTheme);
        });

        function updateThemeIcon(theme) {
            if(theme === 'dark') {
                themeBtn.innerHTML = `<svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
            } else {
                themeBtn.innerHTML = `<svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m11.314 11.314l.707-.707M12 7a5 5 0 100 10 5 5 0 000-10z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`;
            }
        }

        // --- SPA ENGINE: VIEW MANIPULATION ROUTINES ---
        function switchView(viewId) {
            // Deactivate all core view shells
            document.getElementById('mainView').classList.remove('active-view');
            document.getElementById('privacyView').classList.remove('active-view');
            document.getElementById('termsView').classList.remove('active-view');
            
            // Activate designated layout view
            if(viewId === 'main') {
                document.getElementById('mainView').classList.add('active-view');
            } else if(viewId === 'privacy') {
                document.getElementById('privacyView').classList.add('active-view');
                window.scrollTo(0, 0);
            } else if(viewId === 'terms') {
                document.getElementById('termsView').classList.add('active-view');
                window.scrollTo(0, 0);
            }

            // Sync navigation highlights
            const links = document.querySelectorAll('.nav-link');
            links.forEach(l => l.classList.remove('active'));
            event?.target?.classList.add('active');
        }

        // --- ACCORDION EXPANSION MECHANICS ---
        const faqTriggers = document.querySelectorAll('.faq-trigger');
        faqTriggers.forEach(trigger => {
            trigger.addEventListener('click', () => {
                const parent = trigger.parentElement;
                const isOpen = parent.classList.contains('open');
                
                // Close active nodes globally
                document.querySelectorAll('.faq-item').forEach(item => item.classList.remove('open'));
                
                // Open selected node state if closed previously
                if(!isOpen) {
                    parent.classList.add('open');
                }
            });
        });

        // --- LIGHTHOUSE ENGINE: ASSURE 60FPS LAZY SCROLL TRACKING ---
        const observerOptions = { threshold: 0.1, rootMargin: "0px 0px -50px 0px" };
        const scrollObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if(entry.isIntersecting) {
                    entry.target.style.opacity = "1";
                    entry.target.style.transform = "translateY(0)";
                    scrollObserver.unobserve(entry.target);
                }
            });
        }, observerOptions);

        document.querySelectorAll('.feature-card, .timeline-content, .disclosure-panel').forEach(el => {
            el.style.opacity = "0";
            el.style.transform = "translateY(30px)";
            el.style.transition = "opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)";
            scrollObserver.observe(el);
        });
    </script>
