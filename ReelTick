    <!-- ====================================== -->
    <!-- VIEW A: MAIN COMPANY PLATFORM          -->
    <!-- ====================================== -->
    <main id="mainView" class="view-section active-view">
        
        <!-- HERO COMPONENT -->
        <section class="hero" id="home">
            <div class="blob-bg"></div>
            <div class="container hero-grid">
                <div>
                    <h1 class="hero-title">Break the Scroll. <span>Reclaim Time.</span></h1>
