    <style>
        /* --- DESIGN SYSTEM CORE & VARIABLES --- */
        :root {
            --primary: #5B5FEF;
            --secondary: #8B7BFF;
            --accent: #5CE1C6;
            --bg: #F6F7FB;
            --card: rgba(255, 255, 255, 0.75);
            --card-border: rgba(255, 255, 255, 0.6);
            --text: #111827;
            --text-muted: #6B7280;
            --danger: #FF6B6B;
            --success: #22C55E;
            --shadow: rgba(91, 95, 239, 0.08);
            --blur: 20px;
            --glass-glow: rgba(255, 255, 255, 0.4);
        }

        [data-theme="dark"] {
            --bg: #0F1118;
            --card: rgba(27, 31, 42, 0.7);
            --card-border: rgba(255, 255, 255, 0.08);
            --text: #F9FAFB;
            --text-muted: #9CA3AF;
            --shadow: rgba(0, 0, 0, 0.3);
            --glass-glow: rgba(27, 31, 42, 0.2);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Manrope', sans-serif;
            scroll-behavior: smooth;
            transition: background-color 0.4s ease, border-color 0.4s ease, transform 0.2s ease;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- GLOBAL LAYOUT REUSABLES --- */
        .container {
            width: 100%;
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        .section-header {
            text-align: center;
            margin-bottom: 5rem;
        }

        .section-title {
            font-size: 2.75rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, var(--text) 40%, var(--primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .section-subtitle {
            font-size: 1.125rem;
            color: var(--text-muted);
            max-width: 600px;
            margin: 0 auto;
        }

        /* Glassmorphism Preset */
        .glass-panel {
            background: var(--card);
            backdrop-filter: blur(var(--blur));
            -webkit-backdrop-filter: blur(var(--blur));
            border: 1px solid var(--card-border);
            border-radius: 24px;
            box-shadow: 0 8px 32px 0 var(--shadow);
        }

        /* --- NAVIGATION --- */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            border-bottom: 1px solid var(--card-border);
            background: rgba(246, 247, 25B, 0.7);
        }
        [data-theme="dark"] .navbar {
            background: rgba(15, 17, 24, 0.7);
        }

        .nav-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 80px;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--text);
            text-decoration: none;
            letter-spacing: -0.02em;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 900;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 2rem;
            list-style: none;
        }

        .nav-link {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
        }

        .nav-link:hover, .nav-link.active {
            color: var(--primary);
        }

        .controls {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        /* Premium Toggle Switch */
        .theme-toggle {
            background: none;
            border: none;
            cursor: pointer;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text);
            position: relative;
        }
        
        .theme-toggle:hover {
            background: var(--card-border);
        }

        /* --- BUTTONS --- */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.875rem 2rem;
            font-weight: 700;
            border-radius: 14px;
            text-decoration: none;
            cursor: pointer;
            gap: 10px;
            position: relative;
            overflow: hidden;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            border: none;
            box-shadow: 0 4px 15px rgba(91, 95, 239, 0.4);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(91, 95, 239, 0.6);
        }

        .btn-secondary {
            background: var(--card);
            color: var(--text);
            border: 1px solid var(--card-border);
        }

        .btn-secondary:hover {
            background: var(--card-border);
            transform: translateY(-2px);
        }

        /* --- SPA VIEW SHELLS --- */
        .view-section {
            display: none;
            padding-top: 120px;
        }

        .view-section.active-view {
            display: block;
        }

        /* --- HERO SECTION --- */
        .hero {
            position: relative;
            padding: 160px 0 100px;
            overflow: hidden;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 4rem;
            align-items: center;
        }

        .hero-title {
            font-size: 4.5rem;
            font-weight: 800;
            line-height: 1.1;
            letter-spacing: -0.04em;
            margin-bottom: 1.5rem;
        }

        .hero-title span {
            background: linear-gradient(135deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-tagline {
            font-size: 1.25rem;
            color: var(--text-muted);
            margin-bottom: 2.5rem;
            max-width: 560px;
        }

        .hero-buttons {
            display: flex;
            gap: 1.5rem;
            margin-bottom: 4rem;
        }

        /* Luxury Decorative Assets */
        .blob-bg {
            position: absolute;
            width: 500px;
            height: 500px;
            background: linear-gradient(135deg, rgba(91,95,239,0.15), rgba(139,123,255,0.15));
            filter: blur(80px);
            border-radius: 50%;
            top: -10%;
            right: -10%;
            z-index: -1;
            animation: floatBlob 12s infinite alternate ease-in-out;
        }

        @keyframes floatBlob {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(-60px, 40px) scale(1.15); }
        }

        /* Interactive Phone Mockup Layout */
        .phone-mockup-wrapper {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .phone-frame {
            width: 310px;
            height: 630px;
            border: 12px solid #111827;
            border-radius: 44px;
            background: #000;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
            position: relative;
            overflow: hidden;
        }

        .phone-island {
            width: 110px;
            height: 25px;
            background: #111827;
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            border-bottom-left-radius: 18px;
            border-bottom-right-radius: 18px;
            z-index: 10;
        }

        .phone-screen {
            width: 100%;
            height: 100%;
            background: #0F1118;
            padding: 35px 20px 20px;
            display: flex;
            flex-direction: column;
            color: white;
            font-family: system-ui, sans-serif;
        }

        .app-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .app-pill {
            background: rgba(255,255,255,0.08);
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .app-chart-container {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            padding: 20px;
            text-align: center;
            margin-bottom: 20px;
        }

        .chart-value {
            font-size: 2.25rem;
            font-weight: 800;
            color: var(--accent);
            margin-top: 5px;
        }

        .app-log-card {
            background: rgba(255,255,255,0.04);
            border-radius: 14px;
            padding: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
            font-size: 0.85rem;
        }

        .floating-glass-badge {
            position: absolute;
            padding: 1rem;
            border-radius: 18px;
            font-weight: 700;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            animation: badgeFloat 4s infinite alternate ease-in-out;
        }

        .badge-1 { top: 20%; left: -40px; background: rgba(91, 95, 239, 0.2); backdrop-filter: blur(10px); color: var(--text); }
        .badge-2 { bottom: 25%; right: -30px; background: rgba(92, 225, 198, 0.2); backdrop-filter: blur(10px); color: var(--text); animation-delay: 2s; }

        @keyframes badgeFloat {
            0% { transform: translateY(0); }
            100% { transform: translateY(-15px); }
        }

        /* --- FEATURES GRID --- */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
            margin-top: 4rem;
        }

        .feature-card {
            padding: 2.5rem;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .feature-card:hover {
            transform: translateY(-6px);
            border-color: var(--primary);
        }

        .feature-icon-wrapper {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            background: rgba(91, 95, 239, 0.1);
            color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        /* --- HOW IT WORKS TIMELINE --- */
        .timeline {
            position: relative;
            max-width: 900px;
            margin: 4rem auto 0;
            padding: 2rem 0;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: 50%;
            top: 0;
            width: 2px;
            height: 100%;
            background: linear-gradient(to bottom, var(--primary), var(--accent));
            transform: translateX(-50%);
        }

        .timeline-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
            margin-bottom: 4rem;
            position: relative;
        }

        .timeline-item:nth-child(even) {
            flex-direction: row-reverse;
        }

        .timeline-dot {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: var(--bg);
            border: 4px solid var(--primary);
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            z-index: 2;
        }

        .timeline-content {
            width: 45%;
            padding: 2rem;
        }

        /* --- ACCESSIBILITY TRANSPARENCY PANEL --- */
        .disclosure-panel {
            max-width: 900px;
            margin: 0 auto;
            padding: 3.5rem;
            position: relative;
        }

        .disclosure-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            margin-top: 2.5rem;
        }

        .disclosure-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        .disclosure-list li {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            font-weight: 500;
        }

        .disclosure-list.secure li::before {
            content: '✓';
            color: var(--success);
            font-weight: 800;
        }

        .disclosure-list.never li::before {
            content: '✕';
            color: var(--danger);
            font-weight: 800;
        }

        /* --- DATA SAFETY COMPARISON --- */
        .table-wrapper {
            overflow-x: auto;
            margin-top: 3rem;
            border-radius: 16px;
            border: 1px solid var(--card-border);
        }

        .safety-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
            background: var(--card);
        }

        .safety-table th, .safety-table td {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--card-border);
            font-size: 0.95rem;
        }

        .safety-table th {
            background: rgba(91, 95, 239, 0.05);
            font-weight: 700;
            color: var(--text);
        }

        .safety-table td span {
            display: inline-flex;
            align-items: center;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 700;
        }

        .status-negative { background: rgba(255, 107, 107, 0.15); color: var(--danger); }
        .status-positive { background: rgba(34, 197, 94, 0.15); color: var(--success); }

        /* --- LEGAL / TEXT RICH VIEWS (Privacy & Terms) --- */
        .legal-frame {
            max-width: 800px;
            margin: 0 auto 6rem;
            padding: 4rem;
        }

        .legal-meta {
            color: var(--text-muted);
            margin-bottom: 2rem;
            font-size: 0.9rem;
        }

        .legal-block {
            margin-bottom: 2.5rem;
        }

        .legal-block h3 {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            font-weight: 700;
        }

        .legal-block p {
            color: var(--text-muted);
            margin-bottom: 1rem;
        }

        /* --- FAQ SECTION --- */
        .faq-accordion {
            max-width: 840px;
            margin: 4rem auto 0;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .faq-item {
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--card-border);
        }

        .faq-trigger {
            width: 100%;
            padding: 1.5rem;
            background: var(--card);
            border: none;
            color: var(--text);
            text-align: left;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .faq-panel {
            max-height: 0;
            overflow: hidden;
            background: var(--card);
            transition: max-height 0.3s cubic-bezier(0, 1, 0, 1);
        }

        .faq-panel p {
            padding: 0 1.5rem 1.5rem;
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        .faq-item.open .faq-panel {
            max-height: 1000px;
            transition: max-height 0.3s cubic-bezier(1, 0, 1, 0);
        }

        /* --- CONTACT CARDS --- */
        .contact-card {
            max-width: 600px;
            margin: 4rem auto 0;
            padding: 3rem;
            text-align: center;
        }

        .email-link {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--primary);
            text-decoration: none;
            margin: 1.5rem 0;
            display: inline-block;
        }

        /* --- FOOTER --- */
        .footer {
            margin-top: 8rem;
            border-top: 1px solid var(--card-border);
            padding: 4rem 0 2rem;
            background: var(--card);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            margin-bottom: 3rem;
        }

        .footer-links {
            display: flex;
            gap: 3rem;
            justify-content: flex-end;
            list-style: none;
        }

        .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 2rem;
            border-top: 1px solid var(--card-border);
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        /* --- RESPONSIVE ADAPTABILITY ENGINE --- */
        @media (max-width: 1024px) {
            .hero-title { font-size: 3.5rem; }
            .hero-grid { grid-template-columns: 1fr; text-align: center; }
            .hero-tagline { margin: 0 auto 2.5rem; }
            .hero-buttons { justify-content: center; }
            .timeline::before { left: 20px; }
            .timeline-item { flex-direction: row !important; }
            .timeline-dot { left: 20px; transform: none; }
            .timeline-content { width: calc(100% - 60px); margin-left: 60px; padding: 1rem 0; }
            .disclosure-grid { grid-template-columns: 1fr; }
            .footer-grid { grid-template-columns: 1fr; text-align: center; }
            .footer-links { justify-content: center; }
        }

        @media (max-width: 768px) {
            .nav-links { display: none; }
            .section-title { font-size: 2.25rem; }
            .hero-title { font-size: 2.75rem; }
            .disclosure-panel { padding: 2rem; }
            .legal-frame { padding: 2rem; }
        }
    </style>
</head>
