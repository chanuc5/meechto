                            </div>
                            <div style="margin-top: auto; font-size: 0.7rem; text-align: center; color: #6B7280;">
                                Device Protection Status: Secure Active
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- PREMIUM FEATURES CONTAINER -->
        <section class="container" id="features" style="padding: 6rem 2rem;">
